@model IEnumerable<project_image_upload_and_Retrieveving_.Models.Product>

@{
    ViewData["Title"] = "Product List";
}

<h2>Product List</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<a asp-action="AddProduct" class="btn btn-primary mb-3">Add New Product</a>

@if (Model != null && Model.Any())
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Name</th>
                <th>Price</th>
                <th>Image</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr>
                    <td>@product.Name</td>
                    <td>@product.Price</td>
                    <td>
                        @if (!string.IsNullOrEmpty(product.ImagePath))
                        {
                            <img src="~/@product.ImagePath" alt="Product Image" width="100" height="100" />
                        }
                        else
                        {
                            <span>No image</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No products found.</p>
}
